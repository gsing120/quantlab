# ============================================================================
# QuantLab Environment Variables — TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# Polygon.io — Market Data
# ----------------------------------------------------------------------------
# Get your API key from: https://polygon.io/dashboard
# Developer tier or higher recommended for full historical access
POLYGON_API_KEY=your_polygon_api_key_here

# ----------------------------------------------------------------------------
# Anthropic — LLM
# ----------------------------------------------------------------------------
# No Anthropic API key here. Per ADR-005 (docs/DECISIONS.md), all LLM-mediated
# work in QuantLab runs inside Cowork on the Mac Mini. Python never calls the
# Anthropic API directly. Model routing per task type is declared in
# docs/COWORK_BRIEF.md and governed by ADR-006.

# ----------------------------------------------------------------------------
# Interactive Brokers — Paper and Live
# ----------------------------------------------------------------------------
# Paper trading defaults. Live account uses different port.
# TWS paper: 7497 | TWS live: 7496 | Gateway paper: 4002 | Gateway live: 4001
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=DU_your_paper_account_id_here

# Safety flag — must be explicitly set to "LIVE" for real trading
# Leave as PAPER during all development
IBKR_MODE=PAPER

# ----------------------------------------------------------------------------
# Environment
# ----------------------------------------------------------------------------
# "development", "paper", or "production"
QUANTLAB_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
QUANTLAB_LOG_LEVEL=INFO

# Log format: "json" for production, "console" for development
QUANTLAB_LOG_FORMAT=console

# ----------------------------------------------------------------------------
# Data paths (defaults are relative to project root)
# ----------------------------------------------------------------------------
QUANTLAB_DATA_DIR=./data
QUANTLAB_LOGS_DIR=./logs

# ----------------------------------------------------------------------------
# Optional: FRED macro data
# ----------------------------------------------------------------------------
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ----------------------------------------------------------------------------
# Optional: News & Social
# ----------------------------------------------------------------------------
# Reddit (for social sentiment lens, later sprints)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=quantlab/0.1

# NewsAPI or similar (later sprints)
NEWS_API_KEY=
